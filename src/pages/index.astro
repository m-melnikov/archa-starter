---
import Base from "@/layouts/Base.astro";
import Prose from "@/components/starwind/prose";
import { site } from "@/content/site";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale,
};
---

<Base title={site.name} description={site.description} canonicalPath="/" jsonLd={jsonLd}>
  <article class="content-width">
    <Prose>
      <h1>{site.tagline}</h1>
      <p class="text-muted-foreground">{site.description}</p>

      <section>
        <h2>What this is</h2>
        <p>
          Astro Baseline is a boring starter: clear structure, SEO defaults, and minimal CSS. No UI kit. No framework
          runtime.
        </p>
      </section>

      <section>
        <h2>Next steps</h2>
        <ul>
          <li>Customize <code>src/content/site.ts</code></li>
          <li>Adjust tokens in <code>src/styles/partials/tokens.css</code></li>
          <li>Add your pages and components</li>
        </ul>
      </section>
    </Prose>
  </article>
</Base>
