---
import JobPostLayout from "@/components/jobs/JobPostLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("jobs");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<JobPostLayout frontmatter={post.data}>
  <Content />
</JobPostLayout>
