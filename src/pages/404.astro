---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Prose from "@comp/starwind/prose";

const title = "Page not found";
const description = "The page you are looking for does not exist.";
---

<BaseLayout title={title} description={description} canonicalPath="/404" robots="noindex,nofollow" contentCentered>
  <article class="content-width">
    <Prose>
      <h1>404 — Page not found</h1>
      <p class="text-muted-foreground">The page you requested does not exist or has been moved.</p>

      <p>
        <a href="/">Go back to the homepage</a>
      </p>
    </Prose>
  </article>
</BaseLayout>
