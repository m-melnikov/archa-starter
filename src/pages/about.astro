---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Prose from "@comp/starwind/prose";
import { site } from "@data/site";

const title = `About — ${site.name}`;
---

<BaseLayout title={title} description={`About ${site.name}`} canonicalPath="/about">
  <article class="content-width">
    <Prose>
      <h1>About</h1>

      <p class="text-muted-foreground">
        {site.name} is a minimal Astro Example focused on structure, clarity, and build-time decisions.
      </p>

      <p>
        This starter intentionally avoids heavy abstractions. It provides a solid foundation for websites that value
        performance, accessibility, and long-term maintainability.
      </p>

      <p>You are expected to adapt it, extend it, and make it your own.</p>
    </Prose>
  </article>
</BaseLayout>
