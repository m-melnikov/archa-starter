---
import BaseLayout from "@/components/shared/layouts/BaseLayout.astro";
import Prose from "@/components/shared/starwind/prose";
import { site } from "@/content/site";

const title = `Contact — ${site.name}`;
const description = `Contact ${site.name}`;
---

<BaseLayout title={title} description={description} canonicalPath="/contact" contentCentered>
  <article class="content">
    <Prose>
      <h1>Contact</h1>

      <p class="text-muted-foreground">This site does not include a contact form by default.</p>

      <p>If you need to get in touch, you can reach us by email:</p>

      {
        site.author.email && (
          <p>
            <a href={`mailto:${site.author.email}`}>{site.author.email}</a>
          </p>
        )
      }

      <p>This keeps the Example simple and avoids unnecessary JavaScript.</p>
    </Prose>
  </article>
</BaseLayout>
