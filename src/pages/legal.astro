---
import BaseLayout from "@/components/layouts/BaseLayout.astro";
import Prose from "@/components/starwind/prose";
import { site } from "@/content/site";

const title = `Legal — ${site.name}`;
const description = `Legal information for ${site.name}`;
---

<BaseLayout title={title} description={description} canonicalPath="/legal">
  <article class="content">
    <Prose>
      <h1>Legal</h1>

      <p>This website is provided as-is, without any guarantee or warranty.</p>

      <p>Content published on this site may be modified or removed at any time.</p>

      <p>If you have any legal concerns, please contact the site owner.</p>

      {
        site.author.email && (
          <p>
            Contact: <a href={`mailto:${site.author.email}`}>{site.author.email}</a>
          </p>
        )
      }
    </Prose>
  </article>
</BaseLayout>
