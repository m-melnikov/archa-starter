---
import "@/styles/global.css";

import IconBrandGithub from "@tabler/icons/filled/brand-github.svg";
import IconBrandYoutube from "@tabler/icons/filled/brand-youtube.svg";
import IconBrandX from "@tabler/icons/outline/brand-x.svg";
import IconBrandLinkedin from "@tabler/icons/filled/brand-linkedin.svg";

import Cloudflare from "@/components/Cloudflare.astro";
import SEO from "@/components/SEO.astro";
import SkipLink from "@/components/SkipLink.astro";
import Footer1, { type SocialLink } from "@/components/starwind-pro/footer-01/Footer1.astro";
import Navbar1 from "@/components/starwind-pro/navbar-01/Navbar1.astro";
import { site } from "@/content/site";

const {
  title = site.name,
  description = site.description,
  canonicalPath = Astro.url.pathname,
  ogImage = site.seo.ogImage,
  robots = site.seo.robots,
  jsonLd,
  mainCentered = false,
} = Astro.props;

const CF_TOKEN = "XXX";
const canonical = new URL(canonicalPath, site.url).toString();

const socialLinks: SocialLink[] = [
  { name: "Twitter", href: "https://twitter.com", icon: IconBrandX },
  { name: "GitHub", href: "https://github.com", icon: IconBrandGithub },
  { name: "LinkedIn", href: "https://linkedin.com", icon: IconBrandLinkedin },
  { name: "YouTube", href: "https://youtube.com", icon: IconBrandYoutube },
];
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content={site.seo.themeColor} />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      robots={robots}
      jsonLd={jsonLd}
    />
    <Cloudflare token={CF_TOKEN} />
  </head>

  <body>
    <SkipLink />
    <Navbar1 siteName="Career Site" links={site.nav} ctaText="Get Started" ctaHref="#get-started" />
    <main id="main" class:list={["", mainCentered && "grid place-items-center"]}>
      <slot />
    </main>
    <Footer1 socialLinks={socialLinks} companyName="Career Site" />
  </body>
</html>
