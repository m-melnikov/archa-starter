---
import "@/styles/global.css";

import IconBrandGithub from "@tabler/icons/outline/brand-github.svg";
import IconBrandYoutube from "@tabler/icons/outline/brand-youtube.svg";
import IconBrandX from "@tabler/icons/outline/brand-x.svg";
import IconBrandLinkedin from "@tabler/icons/outline/brand-linkedin.svg";
import IconBrandInstagram from "@tabler/icons/outline/brand-instagram.svg";
import IconBrandFacebook from "@tabler/icons/outline/brand-facebook.svg";
import IconBrandWhatsApp from "@tabler/icons/outline/brand-whatsapp.svg";
import IconBrandTelegram from "@tabler/icons/outline/brand-telegram.svg";

import Cloudflare from "@/components/Cloudflare.astro";
import SEO from "@/components/SEO.astro";
import SkipLink from "@/components/SkipLink.astro";
import Footer1, { type SocialLink } from "@/components/starwind-pro/footer-01/Footer1.astro";
import Navbar1 from "@/components/starwind-pro/navbar-01/Navbar1.astro";
import { site } from "@/content/site";
import ThemeToggle from "@/components/ThemeToggle.astro";

const {
  title = site.name,
  description = site.description,
  canonicalPath = Astro.url.pathname,
  ogImage = site.seo.ogImage,
  robots = site.seo.robots,
  jsonLd,
  contentCentered = false,
} = Astro.props;

const CF_TOKEN = "XXX";
const canonical = new URL(canonicalPath, site.url).toString();

const icons: any = {
  Twitter: IconBrandX,
  GitHub: IconBrandGithub,
  LinkedIn: IconBrandLinkedin,
  YouTube: IconBrandYoutube,
  Instagram: IconBrandInstagram,
  Facebook: IconBrandFacebook,
  WhatsApp: IconBrandWhatsApp,
  Telegram: IconBrandTelegram,
};

const socialLinks: SocialLink[] =
  site.author.socials?.map((social) => {
    return {
      name: social.label,
      href: social.href,
      icon: icons[social.label],
    };
  }) ?? [];
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content={site.seo.themeColor} />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      robots={robots}
      jsonLd={jsonLd}
    />
    <ThemeToggle />
    <Cloudflare token={CF_TOKEN} />
  </head>

  <body>
    <SkipLink />
    <Navbar1 siteName="Example Site" links={site.nav} ctaText="Get Started" ctaHref="#get-started" />
    <main id="main" class:list={["", contentCentered && "grid place-items-center"]}>
      <slot />
    </main>
    <Footer1 socialLinks={socialLinks} companyName="Example Site" />
  </body>
</html>
