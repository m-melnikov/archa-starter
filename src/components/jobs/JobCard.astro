---
import type { Job } from "@/components/jobs/JobCardTypes";
import { getIcon } from "@/utils/getIcon";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

interface Props extends HTMLAttributes<"article"> {
  /** Job information */
  job: Job;
  href: string;
}

export const jobCard = tv({});

const { job, href = "", class: className, ...rest } = Astro.props;

const icons = {
  arrow: getIcon("ArrowRightDashed"),
  location: getIcon("Location"),
  clock: getIcon("Clock"),
};
---

<a
  href={href}
  class:list={[
    "bg-card group rounded-md border p-6",
    "hover:bg-muted active:bg-muted focus:bg-muted hover:text-accent-foreground",
    jobCard({ class: className }),
  ]}
  {...rest}
>
  <article class="flex flex-col gap-4">
    <header class="flex flex-col justify-between gap-4 sm:flex-row">
      <div class="flex flex-wrap items-center gap-4">
        <h3 class="text-xl font-bold">{job.title}</h3>
        <span class="bg-muted rounded-xs px-2 py-1">{job.department}</span>
      </div>

      <span class="text-primary-accent group-hover:text-accent-foreground flex items-center gap-1 whitespace-nowrap">
        Apply now <icons.arrow class="size-5.5" aria-hidden />
      </span>
    </header>

    <p>{job.description}</p>

    <footer class="flex gap-5 text-sm">
      <span class="flex items-center gap-2">
        <icons.location class="size-5.5" aria-hidden />
        {job.location}
      </span>
      <span class="flex items-center gap-2">
        <icons.clock class="size-5.5" aria-hidden />
        {job.type}
      </span>
    </footer>
  </article>
</a>
