---
import type { Job } from "@/components/open-roles/JobCardTypes";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

interface Props extends HTMLAttributes<"article"> {
  /** Job information */
  job: Job;
}

export const jobCard = tv({});

const { job, class: className, ...rest } = Astro.props;
---

<article class={jobCard({ class: className })} {...rest}>
  {job.title}
  <br />
  {job.department}
  <br />
  {job.location}
  <br />
</article>
